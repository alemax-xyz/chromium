#!/bin/sh

for arg in --headless --no-sandbox --disable-gpu "$@" ${CHROMIUM_ARGUMENTS}; do
	[ -z "${arg}" -o "${uargs#*|${arg%%=*}|}" != "${uargs}" ] && continue
	uargs="${uargs}|${arg%%=*}|"
	[ "${arg%%=*}" = "--process-timeout" ] && CHROMIUM_TIMEOUT=${arg#--process-timeout=} && continue
	args="${args} ${arg}"
done
cmd="/usr/lib/chromium/chromium ${args}"
test "${CHROMIUM_TIMEOUT}" -gt 0 2>/dev/null && cmd="timeout -t ${CHROMIUM_TIMEOUT} ${cmd}"
exec ${cmd}
